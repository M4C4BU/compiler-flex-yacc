// Potenciacao e radiciacao
println(2 ** 8);
println(sqrt(144.0));
println(sqrt(9.0) ** 2.0);

// Inferencia de tipo com var
var base = 3;
var exp  = 4;
var resultado = base ** exp;
println(resultado);

var assoc = 2.0 ** 2.0 ** 3.0;
println(assoc);


int a = 3;
a /= 3;
println(a);
a *= 3;
println(a);

bool ca = true;
println(ca);